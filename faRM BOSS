local function tp(pos)
    char = player.Character or player.CharacterAdded:Wait()
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(pos)
    end
end

-- ========== LOOP COM 500ms ==========
print("🚀 SISTEMA AUTO TP INICIADO!")
print("⏱️ Velocidade: 500ms entre ações")
print("✅ Remoção de telas de loading ativa")

while true do
    for _, mapa in ipairs(mapas) do
        -- Remote (teleporte de mundo)
        if mapa.remote then
            game:GetService("ReplicatedStorage").BridgeNet.dataRemoteEvent:FireServer(unpack(mapa.remote))
            task.wait(0.5) -- 500ms
        end
        
        -- Teleporte para coordenadas
        tp(mapa.pos)
        task.wait(0.5) -- 500ms
    end
end
