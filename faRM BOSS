-- ========== SCRIPT COMPLETO - VELOCIDADE 500ms ==========
local player = game.Players.LocalPlayer
local char = player.Character or player.CharacterAdded:Wait()

-- ========== REMOVER TELAS DE LOADING (MELHORADO) ==========
task.spawn(function()
    while true do
        for _, gui in pairs(player.PlayerGui:GetChildren()) do
            local nome = gui.Name:lower()
            
            -- Lista completa de telas para remover
            if nome:find("loading") or 
               nome:find("load") or 
               nome:find("teleport") or 
               nome:find("fade") or
               nome:find("black") or
               nome:find("transition") or
               nome:find("travel") or
               nome:find("portal") or
               nome:find("spawn") or
               nome:find("internet") or 
               nome:find("conex") then
                
                pcall(function() gui:Destroy() end)
            end
            
            -- Remove telas pretas
            if gui:IsA("Frame") and gui.BackgroundColor3 == Color3.new(0,0,0) then
                pcall(function() gui:Destroy() end)
            end
        end
        task.wait(0.1)
    end
end)

-- Remove telas novas assim que aparecem
player.PlayerGui.ChildAdded:Connect(function(child)
    task.wait(0.05)
    pcall(function() child:Destroy() end)
end)
