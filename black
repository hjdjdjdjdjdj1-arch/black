        end
    end)
    
    btnAimkill.MouseButton1Click:Connect(function()
        AIMKILL_ATIVO = not AIMKILL_ATIVO
        if AIMKILL_ATIVO then
            btnAimkill.Text = "💀 AIMKILL: LIGADO"
            btnAimkill.TextColor3 = COR_VERDE
        else
