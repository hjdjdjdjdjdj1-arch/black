-- ESP + AIMBOT VELOCIDADE MÁXIMA (INSTANTÂNEO)
-- Coloque em: StarterPlayer > StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local UserInputService = game:GetService("UserInputService")
local localPlayer = Players.LocalPlayer

-- CONFIGURAÇÕES
local ESP_LIGADO = true
local AIMBOT_LIGADO = true

-- CONFIGURAÇÕES DO AIMBOT (VELOCIDADE MÁXIMA)
local AIM_CONFIG = {
    VELOCIDADE = 5000,      -- Velocidade MÁXIMA (0.95 = praticamente instantâneo)
    FOV = 360,              -- Campo de visão TOTAL (mira qualquer lugar da tela)
    DISTANCIA_MAX = 1000,   -- Distância máxima (bem longe)
    MIRA_CABECA = true,     -- Mirar na cabeça
    INSTANTANEO = true,     -- Modo instantâneo (sem suavidade)
}

-- CORES
local VERDE = Color3.fromRGB(0, 255, 0)
local VERMELHO = Color3.fromRGB(255, 0, 0)
local BRANCO = Color3.fromRGB(255, 255, 255)
local AMARELO = Color3.fromRGB(255, 255, 0)

local alvoAtual = nil
local elementosESP = {}

-- FUNÇÃO PARA CRIAR ESP
local function criarESP(jogador)
    local gui = Instance.new("ScreenGui")
    gui.Name = jogador.Name
    gui.ResetOnSpawn = false
    gui.Parent = localPlayer.PlayerGui
    
    -- Box
    local box = Instance.new("Frame")
    box.BackgroundTransparency = 0.6
    box.BackgroundColor3 = VERDE
    box.BorderSizePixel = 3
    box.BorderColor3 = VERDE
    box.Parent = gui
    
    -- Nome
    local nome = Instance.new("TextLabel")
    nome.BackgroundTransparency = 1
    nome.Text = jogador.Name
    nome.TextColor3 = BRANCO
    nome.TextSize = 16
    nome.Font = Enum.Font.GothamBold
    nome.TextStrokeTransparency = 0.3
    nome.Size = UDim2.new(0, 200, 0, 25)
    nome.Parent = gui
    
    -- Distância
    local dist = Instance.new("TextLabel")
    dist.BackgroundTransparency = 1
    dist.Text = "0m"
    dist.TextColor3 = AMARELO
    dist.TextSize = 14
    dist.Font = Enum.Font.GothamBold
    dist.Size = UDim2.new(0, 100, 0, 20)
    dist.Parent = gui
    
    return {gui = gui, box = box, nome = nome, dist = dist}
end

-- FUNÇÃO PARA ATUALIZAR ESP
local function atualizarESP()
    if not ESP_LIGADO then return end
    
    local viewportX, viewportY = Camera.ViewportSize.X, Camera.ViewportSize.Y
    
    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= localPlayer then
            if not elementosESP[jogador] then
                elementosESP[jogador] = criarESP(jogador)
            end
            
            local char = jogador.Character
            if char then
                local humano = char:FindFirstChild("Humanoid")
                local torso = char:FindFirstChild("HumanoidRootPart")
                
                if humano and humano.Health > 0 and torso then
                    local pos, visivel = Camera:WorldToViewportPoint(torso.Position)
                    
                    if visivel and pos.X > 0 and pos.X < viewportX and pos.Y > 0 then
                        local distancia = (torso.Position - Camera.CFrame.Position).Magnitude
                        
                        local altura = math.clamp(250 / distancia, 50, 180)
                        local largura = math.clamp(120 / distancia, 30, 90)
                        
                        local boxX = pos.X - (largura / 2)
                        local boxY = pos.Y - (altura / 1.8)
                        
                        boxX = math.clamp(boxX, 0, viewportX - largura)
                        boxY = math.clamp(boxY, 0, viewportY - altura)
                        
                        elementosESP[jogador].box.Position = UDim2.new(0, boxX, 0, boxY)
                        elementosESP[jogador].box.Size = UDim2.new(0, largura, 0, altura)
                        
                        if jogador == alvoAtual and AIMBOT_LIGADO then
                            elementosESP[jogador].box.BorderColor3 = VERMELHO
                            elementosESP[jogador].nome.TextColor3 = VERMELHO
                        else
                            elementosESP[jogador].box.BorderColor3 = VERDE
                            elementosESP[jogador].nome.TextColor3 = BRANCO
                        end
                        
                        elementosESP[jogador].box.Visible = true
                        
                        local nomeX = pos.X - (elementosESP[jogador].nome.TextBounds.X / 2)
                        local nomeY = boxY - 28
                        nomeX = math.clamp(nomeX, 5, viewportX - 205)
                        nomeY = math.max(nomeY, 5)
                        
                        elementosESP[jogador].nome.Position = UDim2.new(0, nomeX, 0, nomeY)
                        elementosESP[jogador].nome.Visible = true
                        
                        local distX = pos.X - (elementosESP[jogador].dist.TextBounds.X / 2)
                        local distY = boxY + altura + 5
                        distX = math.clamp(distX, 5, viewportX - 105)
                        distY = math.min(distY, viewportY - 25)
                        
                        elementosESP[jogador].dist.Position = UDim2.new(0, distX, 0, distY)
                        elementosESP[jogador].dist.Text = math.floor(distancia) .. "m"
                        elementosESP[jogador].dist.Visible = true
                    else
                        elementosESP[jogador].box.Visible = false
                        elementosESP[jogador].nome.Visible = false
                        elementosESP[jogador].dist.Visible = false
                    end
                else
                    elementosESP[jogador].box.Visible = false
                    elementosESP[jogador].nome.Visible = false
                    elementosESP[jogador].dist.Visible = false
                end
            end
        end
    end
end

-- AIMBOT VELOCIDADE MÁXIMA (INSTANTÂNEO)
local function encontrarAlvoRapido()
    local melhorAlvo = nil
    local menorDistancia = math.huge
    local centroX = Camera.ViewportSize.X / 2
    local centroY = Camera.ViewportSize.Y / 2
    
    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= localPlayer and jogador.Character then
            local char = jogador.Character
            local humano = char:FindFirstChild("Humanoid")
            
            if humano and humano.Health > 0 then
                local parteCorpo
                if AIM_CONFIG.MIRA_CABECA then
                    parteCorpo = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
                else
                    parteCorpo = char:FindFirstChild("HumanoidRootPart")
                end
                
                if parteCorpo then
                    local distanciaMundo = (parteCorpo.Position - Camera.CFrame.Position).Magnitude
                    if distanciaMundo > AIM_CONFIG.DISTANCIA_MAX then
                        continue
                    end
                    
                    local posTela, visivel = Camera:WorldToViewportPoint(parteCorpo.Position)
                    
                    if visivel then
                        local diffX = posTela.X - centroX
                        local diffY = posTela.Y - centroY
                        local distCentro = math.sqrt(diffX^2 + diffY^2)
                        
                        if distCentro < AIM_CONFIG.FOV and distCentro < menorDistancia then
                            menorDistancia = distCentro
                            melhorAlvo = jogador
                        end
                    end
                end
            end
        end
    end
    
    return melhorAlvo
end

-- MIRAR INSTANTÂNEO (VELOCIDADE MÁXIMA)
local function mirarInstantaneo(alvo)
    if not alvo or not alvo.Character then return end
    
    local char = alvo.Character
    local parteCorpo
    
    if AIM_CONFIG.MIRA_CABECA then
        parteCorpo = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
    else
        parteCorpo = char:FindFirstChild("HumanoidRootPart")
    end
    
    if not parteCorpo then return end
    
    local posTela = Camera:WorldToViewportPoint(parteCorpo.Position)
    local centroX = Camera.ViewportSize.X / 2
    local centroY = Camera.ViewportSize.Y / 2
    
    local diffX = posTela.X - centroX
    local diffY = posTela.Y - centroY
    
    -- MODO INSTANTÂNEO - Move diretamente para o alvo
    if AIM_CONFIG.INSTANTANEO then
        -- Move o mouse DIRETO para a posição do alvo
        local alvoX = centroX + diffX
        local alvoY = centroY + diffY
        
        alvoX = math.clamp(alvoX, 0, Camera.ViewportSize.X)
        alvoY = math.clamp(alvoY, 0, Camera.ViewportSize.Y)
        
        UserInputService:SetMouseLocation(alvoX, alvoY)
    else
        -- Modo suave (mais lento)
        if math.abs(diffX) > 5 or math.abs(diffY) > 5 then
            local moveX = diffX * AIM_CONFIG.VELOCIDADE
            local moveY = diffY * AIM_CONFIG.VELOCIDADE
            
            moveX = math.clamp(moveX, -100, 100)
            moveY = math.clamp(moveY, -100, 100)
            
            local posAtual = UserInputService:GetMouseLocation()
            local novaX = math.clamp(posAtual.X + moveX, 0, Camera.ViewportSize.X)
            local novaY = math.clamp(posAtual.Y + moveY, 0, Camera.ViewportSize.Y)
            
            UserInputService:SetMouseLocation(novaX, novaY)
        end
    end
end

-- CRIAR MENU
local function criarMenu()
    local gui = Instance.new("ScreenGui")
    gui.Name = "Menu"
    gui.ResetOnSpawn = false
    gui.Parent = localPlayer.PlayerGui
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 200, 0, 110)
    frame.Position = UDim2.new(0, 10, 0, 10)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.4
    frame.BorderSizePixel = 3
    frame.BorderColor3 = VERDE
    frame.Parent = gui
    
    -- Botão ESP
    local btnESP = Instance.new("TextButton")
    btnESP.Size = UDim2.new(0, 180, 0, 40)
    btnESP.Position = UDim2.new(0, 10, 0, 10)
    btnESP.Text = "⚡ ESP: LIGADO"
    btnESP.TextColor3 = VERDE
    btnESP.TextSize = 18
    btnESP.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btnESP.BorderSizePixel = 1
    btnESP.Parent = frame
    
    -- Botão AIMBOT
    local btnAim = Instance.new("TextButton")
    btnAim.Size = UDim2.new(0, 180, 0, 40)
    btnAim.Position = UDim2.new(0, 10, 0, 60)
    btnAim.Text = "🎯 AIMBOT: LIGADO (INSTANTÂNEO)"
    btnAim.TextColor3 = VERDE
    btnAim.TextSize = 16
    btnAim.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
    btnAim.BorderSizePixel = 1
    btnAim.Parent = frame
    
    btnESP.MouseButton1Click:Connect(function()
        ESP_LIGADO = not ESP_LIGADO
        if ESP_LIGADO then
            btnESP.Text = "⚡ ESP: LIGADO"
            btnESP.TextColor3 = VERDE
            frame.BorderColor3 = VERDE
        else
            btnESP.Text = "⚡ ESP: DESLIGADO"
            btnESP.TextColor3 = VERMELHO
            frame.BorderColor3 = VERMELHO
            for _, esp in pairs(elementosESP) do
                if esp and esp.gui then
                    esp.gui:Destroy()
                end
            end
            elementosESP = {}
        end
    end)
    
    btnAim.MouseButton1Click:Connect(function()
        AIMBOT_LIGADO = not AIMBOT_LIGADO
        if AIMBOT_LIGADO then
            btnAim.Text = "🎯 AIMBOT: LIGADO (INSTANTÂNEO)"
            btnAim.TextColor3 = VERDE
        else
            btnAim.Text = "🎯 AIMBOT: DESLIGADO"
            btnAim.TextColor3 = VERMELHO
            alvoAtual = nil
        end
    end)
end

-- LIMPAR JOGADORES
Players.PlayerRemoving:Connect(function(jogador)
    if elementosESP[jogador] then
        elementosESP[jogador].gui:Destroy()
        elementosESP[jogador] = nil
    end
    if alvoAtual == jogador then
        alvoAtual = nil
    end
end)

-- LOOP PRINCIPAL
RunService.RenderStepped:Connect(function()
    -- ESP
    atualizarESP()
    
    -- AIMBOT VELOCIDADE MÁXIMA
    if AIMBOT_LIGADO and ESP_LIGADO then
        local novoAlvo = encontrarAlvoRapido()
        if novoAlvo then
            alvoAtual = novoAlvo
            mirarInstantaneo(alvoAtual) -- MIRA INSTANTÂNEA
        else
            alvoAtual = nil
        end
    end
end)

-- INICIAR
criarMenu()

print("⚡ AIMBOT VELOCIDADE MÁXIMA ATIVADO!")
print("🎯 Mira INSTANTÂNEA no inimigo")
print("📱 Perfeito para CELULAR")
