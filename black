-- ESP + AIMBOT PARA CELULAR/CONSOLE (CORRIGIDO)
-- Coloque em: StarterPlayer > StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera

local localPlayer = Players.LocalPlayer
local Mouse = localPlayer:GetMouse()

-- Configurações
local ESP_ATIVO = true
local AIMBOT_ATIVO = true

-- Cores
local COR_VERDE = Color3.fromRGB(0, 255, 0)
local COR_VERMELHA = Color3.fromRGB(255, 0, 0)
local COR_BRANCA = Color3.fromRGB(255, 255, 255)

local alvoAtual = nil
local objetosESP = {}

-- FUNÇÃO PARA CRIAR UI DO JOGADOR (OTIMIZADO PARA CELULAR)
local function criarESP(jogador)
    local tela = Instance.new("ScreenGui")
    tela.Name = jogador.Name .. "_ESP"
    tela.ResetOnSpawn = false
    tela.DisplayOrder = 999 -- Garante que fique na frente
    
    -- Box do jogador (ajustado para celular)
    local box = Instance.new("Frame")
    box.Name = "Box"
    box.BackgroundTransparency = 0.7
    box.BackgroundColor3 = COR_VERDE
    box.BorderSizePixel = 3
    box.BorderColor3 = COR_VERDE
    box.Visible = true
    box.Parent = tela
    
    -- Nome do jogador (texto maior para celular)
    local nome = Instance.new("TextLabel")
    nome.Name = "Nome"
    nome.Text = jogador.Name
    nome.TextColor3 = COR_BRANCA
    nome.TextSize = 18
    nome.Font = Enum.Font.GothamBold
    nome.BackgroundTransparency = 1
    nome.TextStrokeTransparency = 0.2
    nome.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    nome.Size = UDim2.new(0, 250, 0, 25)
    nome.Parent = tela
    
    -- Distância
    local distancia = Instance.new("TextLabel")
    distancia.Name = "Distancia"
    distancia.Text = "0m"
    distancia.TextColor3 = COR_BRANCA
    distancia.TextSize = 16
    distancia.Font = Enum.Font.Gotham
    distancia.BackgroundTransparency = 1
    distancia.TextStrokeTransparency = 0.2
    distancia.TextStrokeColor3 = Color3.fromRGB(0, 0, 0)
    distancia.Size = UDim2.new(0, 120, 0, 20)
    distancia.Parent = tela
    
    return {
        GUI = tela,
        Box = box,
        Nome = nome,
        Distancia = distancia
    }
end

-- FUNÇÃO PARA ATUALIZAR ESP (CORRIGIDA PARA CELULAR)
local function atualizarESP()
    if not ESP_ATIVO then return end
    
    local viewportSize = Camera.ViewportSize
    
    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= localPlayer and jogador.Character then
            -- Criar ESP se não existir
            if not objetosESP[jogador] then
                objetosESP[jogador] = criarESP(jogador)
                objetosESP[jogador].GUI.Parent = localPlayer.PlayerGui
            end
            
            local personagem = jogador.Character
            local torso = personagem:FindFirstChild("HumanoidRootPart") or personagem:FindFirstChild("Torso") or personagem:FindFirstChild("UpperTorso")
            local humanoide = personagem:FindFirstChild("Humanoid")
            
            if torso and humanoide and humanoide.Health > 0 then
                -- Posição na tela
                local posicaoTela, naTela = Camera:WorldToViewportPoint(torso.Position)
                
                -- Verifica se está dentro da tela (com margem)
                if naTela and posicaoTela.X > 0 and posicaoTela.X < viewportSize.X and 
                   posicaoTela.Y > 0 and posicaoTela.Y < viewportSize.Y then
                    
                    -- Calcular distância
                    local distancia = (torso.Position - Camera.CFrame.Position).Magnitude
                    local distanciaMetros = math.floor(distancia)
                    
                    -- Tamanho da box baseado na distância (ajustado para celular)
                    local alturaBox = math.clamp(300 / distancia, 50, 200)
                    local larguraBox = math.clamp(150 / distancia, 30, 120)
                    
                    -- Posicionar box (CORRIGIDO - não vai mais para baixo da tela)
                    local boxX = posicaoTela.X - (larguraBox / 2)
                    local boxY = posicaoTela.Y - (alturaBox / 2) -- Mudado de 1.5 para 2
                    
                    -- Garantir que a box não saia da tela
                    boxX = math.clamp(boxX, 0, viewportSize.X - larguraBox)
                    boxY = math.clamp(boxY, 0, viewportSize.Y - alturaBox)
                    
                    objetosESP[jogador].Box.Position = UDim2.new(0, boxX, 0, boxY)
                    objetosESP[jogador].Box.Size = UDim2.new(0, larguraBox, 0, alturaBox)
                    
                    -- Box VERMELHA se for o alvo
                    if jogador == alvoAtual and AIMBOT_ATIVO then
                        objetosESP[jogador].Box.BorderColor3 = COR_VERMELHA
                        objetosESP[jogador].Nome.TextColor3 = COR_VERMELHA
                    else
                        objetosESP[jogador].Box.BorderColor3 = COR_VERDE
                        objetosESP[jogador].Nome.TextColor3 = COR_BRANCA
                    end
                    
                    objetosESP[jogador].Box.Visible = true
                    
                    -- Posicionar nome (acima da box)
                    local nomeX = posicaoTela.X - (objetosESP[jogador].Nome.TextBounds.X / 2)
                    local nomeY = boxY - 28
                    
                    -- Garantir que o nome não saia da tela
                    nomeX = math.clamp(nomeX, 5, viewportSize.X - objetosESP[jogador].Nome.TextBounds.X - 5)
                    nomeY = math.max(nomeY, 5)
                    
                    objetosESP[jogador].Nome.Position = UDim2.new(0, nomeX, 0, nomeY)
                    objetosESP[jogador].Nome.Visible = true
                    
                    -- Posicionar distância (abaixo da box)
                    local distY = boxY + alturaBox + 5
                    local distX = posicaoTela.X - (objetosESP[jogador].Distancia.TextBounds.X / 2)
                    
                    -- Garantir que a distância não saia da tela
                    distX = math.clamp(distX, 5, viewportSize.X - objetosESP[jogador].Distancia.TextBounds.X - 5)
                    distY = math.min(distY, viewportSize.Y - 25)
                    
                    objetosESP[jogador].Distancia.Position = UDim2.new(0, distX, 0, distY)
                    objetosESP[jogador].Distancia.Text = distanciaMetros .. "m"
                    objetosESP[jogador].Distancia.Visible = true
                else
                    -- Fora da tela, esconder elementos
                    objetosESP[jogador].Box.Visible = false
                    objetosESP[jogador].Nome.Visible = false
                    objetosESP[jogador].Distancia.Visible = false
                end
            else
                objetosESP[jogador].Box.Visible = false
                objetosESP[jogador].Nome.Visible = false
                objetosESP[jogador].Distancia.Visible = false
            end
        elseif objetosESP[jogador] then
            objetosESP[jogador].GUI:Destroy()
            objetosESP[jogador] = nil
        end
    end
end

-- FUNÇÃO PARA VERIFICAR SE HÁ JOGADORES VÁLIDOS
local function temJogadoresValidos()
    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= localPlayer and jogador.Character then
            local humanoide = jogador.Character:FindFirstChild("Humanoid")
            if humanoide and humanoide.Health > 0 then
                return true
            end
        end
    end
    return false
end

-- FUNÇÃO PARA ENCONTRAR MELHOR ALVO
local function encontrarAlvo()
    if not temJogadoresValidos() then
        return nil
    end
    
    local melhorAlvo = nil
    local menorDistanciaCentro = math.huge
    local centroTela = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= localPlayer and jogador.Character then
            local personagem = jogador.Character
            local cabeca = personagem:FindFirstChild("Head") or personagem:FindFirstChild("HumanoidRootPart")
            local humanoide = personagem:FindFirstChild("Humanoid")
            
            if cabeca and humanoide and humanoide.Health > 0 then
                local posTela, visivel = Camera:WorldToViewportPoint(cabeca.Position)
                
                if visivel and posTela.X > 0 and posTela.X < Camera.ViewportSize.X and
                   posTela.Y > 0 and posTela.Y < Camera.ViewportSize.Y then
                    
                    local distanciaCentro = (Vector2.new(posTela.X, posTela.Y) - centroTela).Magnitude
                    
                    if distanciaCentro < 300 and distanciaCentro < menorDistanciaCentro then
                        local raycast = RaycastParams.new()
                        raycast.FilterType = Enum.RaycastFilterType.Blacklist
                        raycast.FilterDescendantsInstances = {localPlayer.Character, personagem}
                        
                        local origem = Camera.CFrame.Position
                        local direcao = (cabeca.Position - origem).Unit
                        local distancia = (cabeca.Position - origem).Magnitude
                        local resultado = workspace:Raycast(origem, direcao * distancia, raycast)
                        
                        if not resultado or resultado.Instance:IsDescendantOf(personagem) then
                            menorDistanciaCentro = distanciaCentro
                            melhorAlvo = jogador
                        end
                    end
                end
            end
        end
    end
    
    return melhorAlvo
end

-- FUNÇÃO PARA MIRAR NO ALVO (OTIMIZADA)
local function mirarNoAlvo(alvo)
    if not alvo or not alvo.Character then return end
    
    local personagem = alvo.Character
    local cabeca = personagem:FindFirstChild("Head") or personagem:FindFirstChild("HumanoidRootPart")
    
    if cabeca then
        local posTela = Camera:WorldToViewportPoint(cabeca.Position)
        local centroTela = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
        local diferenca = Vector2.new(posTela.X - centroTela.X, posTela.Y - centroTela.Y)
        
        if math.abs(diferenca.X) > 15 or math.abs(diferenca.Y) > 15 then
            local moveX = math.clamp(diferenca.X * 0.25, -20, 20)
            local moveY = math.clamp(diferenca.Y * 0.25, -20, 20)
            
            if math.abs(moveX) > 1 or math.abs(moveY) > 1 then
                local UIS = game:GetService("UserInputService")
                local posAtual = UIS:GetMouseLocation()
                local novaX = math.clamp(posAtual.X + moveX, 0, Camera.ViewportSize.X)
                local novaY = math.clamp(posAtual.Y + moveY, 0, Camera.ViewportSize.Y)
                
                UIS.MouseBehavior = Enum.MouseBehavior.Default
                UIS:SetMouseLocation(novaX, novaY)
            end
        end
    end
end

-- CRIAR INTERFACE DE CONTROLE (OTIMIZADA PARA CELULAR)
local function criarUI()
    local telaUI = Instance.new("ScreenGui")
    telaUI.Name = "MenuESP"
    telaUI.ResetOnSpawn = false
    telaUI.DisplayOrder = 1000
    telaUI.Parent = localPlayer.PlayerGui
    
    -- Menu adaptado para toque (botões maiores)
    local menu = Instance.new("Frame")
    menu.Size = UDim2.new(0, 180, 0, 100)
    menu.Position = UDim2.new(0, 10, 0, 10)
    menu.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    menu.BackgroundTransparency = 0.6
    menu.BorderSizePixel = 3
    menu.BorderColor3 = COR_VERDE
    menu.Parent = telaUI
    
    -- Botão ESP (maior para celular)
    local btnESP = Instance.new("TextButton")
    btnESP.Size = UDim2.new(0, 160, 0, 35)
    btnESP.Position = UDim2.new(0, 10, 0, 10)
    btnESP.Text = "ESP: LIGADO"
    btnESP.TextColor3 = COR_VERDE
    btnESP.TextSize = 18
    btnESP.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btnESP.BorderSizePixel = 2
    btnESP.Parent = menu
    
    -- Botão AIMBOT (maior para celular)
    local btnAimbot = Instance.new("TextButton")
    btnAimbot.Size = UDim2.new(0, 160, 0, 35)
    btnAimbot.Position = UDim2.new(0, 10, 0, 55)
    btnAimbot.Text = "AIMBOT: LIGADO"
    btnAimbot.TextColor3 = COR_VERDE
    btnAimbot.TextSize = 18
    btnAimbot.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btnAimbot.BorderSizePixel = 2
    btnAimbot.Parent = menu
    
    -- Funções dos botões
    btnESP.MouseButton1Click:Connect(function()
        ESP_ATIVO = not ESP_ATIVO
        if ESP_ATIVO then
            btnESP.Text = "ESP: LIGADO"
            btnESP.TextColor3 = COR_VERDE
            menu.BorderColor3 = COR_VERDE
        else
            btnESP.Text = "ESP: DESLIGADO"
            btnESP.TextColor3 = COR_VERMELHA
            menu.BorderColor3 = COR_VERMELHA
            -- Limpar ESP
            for _, obj in pairs(objetosESP) do
                if obj and obj.GUI then
                    obj.GUI:Destroy()
                end
            end
            objetosESP = {}
        end
    end)
    
    btnAimbot.MouseButton1Click:Connect(function()
        AIMBOT_ATIVO = not AIMBOT_ATIVO
        if AIMBOT_ATIVO then
            btnAimbot.Text = "AIMBOT: LIGADO"
            btnAimbot.TextColor3 = COR_VERDE
        else
            btnAimbot.Text = "AIMBOT: DESLIGADO"
            btnAimbot.TextColor3 = COR_VERMELHA
            alvoAtual = nil
        end
    end)
end

-- LOOP PRINCIPAL
RunService.RenderStepped:Connect(function()
    atualizarESP()
    
    if AIMBOT_ATIVO and ESP_ATIVO then
        local novoAlvo = encontrarAlvo()
        if novoAlvo then
            alvoAtual = novoAlvo
            mirarNoAlvo(alvoAtual)
        else
            alvoAtual = nil
        end
    else
        alvoAtual = nil
    end
end)

-- EVENTOS DE JOGADORES
Players.PlayerAdded:Connect(function(jogador)
    if jogador ~= localPlayer then
        task.wait(1)
        if ESP_ATIVO and not objetosESP[jogador] then
            objetosESP[jogador] = criarESP(jogador)
            objetosESP[jogador].GUI.Parent = localPlayer.PlayerGui
        end
    end
end)

Players.PlayerRemoving:Connect(function(jogador)
    if objetosESP[jogador] then
        objetosESP[jogador].GUI:Destroy()
        objetosESP[jogador] = nil
    end
    if alvoAtual == jogador then
        alvoAtual = nil
    end
end)

-- INICIALIZAR
criarUI()

-- Criar ESP para jogadores existentes
task.wait(1)
for _, jogador in pairs(Players:GetPlayers()) do
    if jogador ~= localPlayer then
        objetosESP[jogador] = criarESP(jogador)
        objetosESP[jogador].GUI.Parent = localPlayer.PlayerGui
    end
end

