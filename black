-- ESP SIMPLES E FUNCIONAL (TESTADO)
-- Coloque em: StarterPlayer > StarterPlayerScripts

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local localPlayer = Players.LocalPlayer

-- Configurações
local ESP_LIGADO = true
local AIMBOT_LIGADO = true

-- Cores
local VERDE = Color3.fromRGB(0, 255, 0)
local VERMELHO = Color3.fromRGB(255, 0, 0)
local BRANCO = Color3.fromRGB(255, 255, 255)

local alvoAtual = nil
local elementosESP = {}

-- CRIAR ELEMENTOS DO ESP
local function criarElementos(jogador)
    local gui = Instance.new("ScreenGui")
    gui.Name = jogador.Name
    gui.ResetOnSpawn = false
    gui.Parent = localPlayer.PlayerGui
    
    -- Box
    local box = Instance.new("Frame")
    box.Size = UDim2.new(0, 100, 0, 100)
    box.BackgroundTransparency = 0.7
    box.BackgroundColor3 = VERDE
    box.BorderSizePixel = 2
    box.BorderColor3 = VERDE
    box.Parent = gui
    
    -- Nome
    local nome = Instance.new("TextLabel")
    nome.Size = UDim2.new(0, 150, 0, 20)
    nome.BackgroundTransparency = 1
    nome.Text = jogador.Name
    nome.TextColor3 = BRANCO
    nome.TextSize = 14
    nome.Font = Enum.Font.GothamBold
    nome.Parent = gui
    
    -- Distância
    local dist = Instance.new("TextLabel")
    dist.Size = UDim2.new(0, 80, 0, 16)
    dist.BackgroundTransparency = 1
    dist.Text = "0m"
    dist.TextColor3 = BRANCO
    dist.TextSize = 12
    dist.Font = Enum.Font.Gotham
    dist.Parent = gui
    
    return {
        gui = gui,
        box = box,
        nome = nome,
        dist = dist
    }
end

-- ATUALIZAR POSIÇÕES
local function atualizarESP()
    if not ESP_LIGADO then return end
    
    local viewportX = Camera.ViewportSize.X
    local viewportY = Camera.ViewportSize.Y
    
    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= localPlayer then
            -- Criar elementos se não existir
            if not elementosESP[jogador] then
                elementosESP[jogador] = criarElementos(jogador)
            end
            
            local char = jogador.Character
            if char then
                local humano = char:FindFirstChild("Humanoid")
                local torso = char:FindFirstChild("HumanoidRootPart") or char:FindFirstChild("Torso")
                
                if humano and humano.Health > 0 and torso then
                    -- Pegar posição na tela
                    local pos, visivel = Camera:WorldToViewportPoint(torso.Position)
                    
                    if visivel and pos.X > 0 and pos.X < viewportX and pos.Y > 0 and pos.Y < viewportY then
                        -- Calcular distância
                        local distancia = (torso.Position - Camera.CFrame.Position).Magnitude
                        
                        -- Tamanho da box baseado na distância
                        local altura = math.clamp(300 / distancia, 40, 150)
                        local largura = math.clamp(150 / distancia, 30, 80)
                        
                        -- Posição da box (centralizada no torso)
                        local boxX = pos.X - (largura / 2)
                        local boxY = pos.Y - (altura / 1.5)
                        
                        -- Garantir que fique na tela
                        boxX = math.clamp(boxX, 0, viewportX - largura)
                        boxY = math.clamp(boxY, 0, viewportY - altura)
                        
                        -- Aplicar posição e tamanho
                        elementosESP[jogador].box.Position = UDim2.new(0, boxX, 0, boxY)
                        elementosESP[jogador].box.Size = UDim2.new(0, largura, 0, altura)
                        
                        -- Cor da box (vermelha se for alvo)
                        if jogador == alvoAtual and AIMBOT_LIGADO then
                            elementosESP[jogador].box.BorderColor3 = VERMELHO
                            elementosESP[jogador].nome.TextColor3 = VERMELHO
                        else
                            elementosESP[jogador].box.BorderColor3 = VERDE
                            elementosESP[jogador].nome.TextColor3 = BRANCO
                        end
                        
                        elementosESP[jogador].box.Visible = true
                        
                        -- Posição do nome (acima da box)
                        local nomeX = pos.X - (elementosESP[jogador].nome.TextBounds.X / 2)
                        local nomeY = boxY - 22
                        nomeX = math.clamp(nomeX, 5, viewportX - 155)
                        nomeY = math.max(nomeY, 5)
                        
                        elementosESP[jogador].nome.Position = UDim2.new(0, nomeX, 0, nomeY)
                        elementosESP[jogador].nome.Visible = true
                        
                        -- Posição da distância (abaixo da box)
                        local distX = pos.X - (elementosESP[jogador].dist.TextBounds.X / 2)
                        local distY = boxY + altura + 5
                        distX = math.clamp(distX, 5, viewportX - 85)
                        distY = math.min(distY, viewportY - 21)
                        
                        elementosESP[jogador].dist.Position = UDim2.new(0, distX, 0, distY)
                        elementosESP[jogador].dist.Text = math.floor(distancia) .. "m"
                        elementosESP[jogador].dist.Visible = true
                    else
                        -- Fora da tela
                        elementosESP[jogador].box.Visible = false
                        elementosESP[jogador].nome.Visible = false
                        elementosESP[jogador].dist.Visible = false
                    end
                else
                    elementosESP[jogador].box.Visible = false
                    elementosESP[jogador].nome.Visible = false
                    elementosESP[jogador].dist.Visible = false
                end
            else
                elementosESP[jogador].box.Visible = false
                elementosESP[jogador].nome.Visible = false
                elementosESP[jogador].dist.Visible = false
            end
        end
    end
end

-- ENCONTRAR MELHOR ALVO PARA AIMBOT
local function encontrarAlvo()
    local melhorAlvo = nil
    local menorDistanciaCentro = math.huge
    local centroX = Camera.ViewportSize.X / 2
    local centroY = Camera.ViewportSize.Y / 2
    
    for _, jogador in pairs(Players:GetPlayers()) do
        if jogador ~= localPlayer and jogador.Character then
            local char = jogador.Character
            local humano = char:FindFirstChild("Humanoid")
            local cabeca = char:FindFirstChild("Head") or char:FindFirstChild("HumanoidRootPart")
            
            if cabeca and humano and humano.Health > 0 then
                local pos, visivel = Camera:WorldToViewportPoint(cabeca.Position)
                
                if visivel then
                    -- Distância do centro da tela
                    local distCentro = math.sqrt((pos.X - centroX)^2 + (pos.Y - centroY)^2)
                    
                    if distCentro < 200 and distCentro < menorDistanciaCentro then
                        -- Verificar parede
                        local raycast = RaycastParams.new()
                        raycast.FilterType = Enum.RaycastFilterType.Blacklist
                        raycast.FilterDescendantsInstances = {localPlayer.Character, char}
                        
                        local origem = Camera.CFrame.Position
                        local direcao = (cabeca.Position - origem).Unit
                        local distancia = (cabeca.Position - origem).Magnitude
                        local resultado = workspace:Raycast(origem, direcao * distancia, raycast)
                        
                        if not resultado or resultado.Instance:IsDescendantOf(char) then
                            menorDistanciaCentro = distCentro
                            melhorAlvo = jogador
                        end
                    end
                end
            end
        end
    end
    
    return melhorAlvo
end

-- MIRAR NO ALVO
local function mirar(alvo)
    if not alvo or not alvo.Character then return end
    
    local cabeca = alvo.Character:FindFirstChild("Head") or alvo.Character:FindFirstChild("HumanoidRootPart")
    if not cabeca then return end
    
    local posTela = Camera:WorldToViewportPoint(cabeca.Position)
    local centroX = Camera.ViewportSize.X / 2
    local centroY = Camera.ViewportSize.Y / 2
    
    local diffX = posTela.X - centroX
    local diffY = posTela.Y - centroY
    
    if math.abs(diffX) > 5 or math.abs(diffY) > 5 then
        local UIS = game:GetService("UserInputService")
        local posAtual = UIS:GetMouseLocation()
        local novaX = posAtual.X + (diffX * 0.2)
        local novaY = posAtual.Y + (diffY * 0.2)
        
        novaX = math.clamp(novaX, 0, Camera.ViewportSize.X)
        novaY = math.clamp(novaY, 0, Camera.ViewportSize.Y)
        
        UIS:SetMouseLocation(novaX, novaY)
    end
end

-- CRIAR MENU
local function criarMenu()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "MenuESP"
    screenGui.ResetOnSpawn = false
    screenGui.Parent = localPlayer.PlayerGui
    
    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 150, 0, 80)
    frame.Position = UDim2.new(0, 10, 0, 10)
    frame.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
    frame.BackgroundTransparency = 0.5
    frame.BorderSizePixel = 2
    frame.BorderColor3 = VERDE
    frame.Parent = screenGui
    
    -- Botão ESP
    local btnESP = Instance.new("TextButton")
    btnESP.Size = UDim2.new(0, 130, 0, 30)
    btnESP.Position = UDim2.new(0, 10, 0, 10)
    btnESP.Text = "ESP: ON"
    btnESP.TextColor3 = VERDE
    btnESP.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btnESP.Parent = frame
    
    -- Botão Aimbot
    local btnAim = Instance.new("TextButton")
    btnAim.Size = UDim2.new(0, 130, 0, 30)
    btnAim.Position = UDim2.new(0, 10, 0, 45)
    btnAim.Text = "AIMBOT: ON"
    btnAim.TextColor3 = VERDE
    btnAim.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
    btnAim.Parent = frame
    
    btnESP.MouseButton1Click:Connect(function()
        ESP_LIGADO = not ESP_LIGADO
        if ESP_LIGADO then
            btnESP.Text = "ESP: ON"
            btnESP.TextColor3 = VERDE
            frame.BorderColor3 = VERDE
        else
            btnESP.Text = "ESP: OFF"
            btnESP.TextColor3 = VERMELHO
            frame.BorderColor3 = VERMELHO
            -- Limpar tudo
            for _, esp in pairs(elementosESP) do
                if esp and esp.gui then
                    esp.gui:Destroy()
                end
            end
            elementosESP = {}
        end
    end)
    
    btnAim.MouseButton1Click:Connect(function()
        AIMBOT_LIGADO = not AIMBOT_LIGADO
        if AIMBOT_LIGADO then
            btnAim.Text = "AIMBOT: ON"
            btnAim.TextColor3 = VERDE
        else
            btnAim.Text = "AIMBOT: OFF"
            btnAim.TextColor3 = VERMELHO
            alvoAtual = nil
        end
    end)
end

-- LIMPAR QUANDO JOGADOR SAI
Players.PlayerRemoving:Connect(function(jogador)
    if elementosESP[jogador] then
        elementosESP[jogador].gui:Destroy()
        elementosESP[jogador] = nil
    end
    if alvoAtual == jogador then
        alvoAtual = nil
    end
end)

-- LOOP PRINCIPAL
RunService.RenderStepped:Connect(function()
    atualizarESP()
    
    if AIMBOT_LIGADO and ESP_LIGADO then
        alvoAtual = encontrarAlvo()
        if alvoAtual then
            mirar(alvoAtual)
        end
    end
end)

-- INICIAR
criarMenu()

print("✅ ESP CARREGADO - Versão Simplificada")
