-- Iniciar/Parar
botaoIniciar.MouseButton1Click:Connect(function()
    local temSelecionado = false
    for i = 1, 4 do
        if config.mapasSelecionados[i] then
            temSelecionado = true
            break
        end
    end
    
    if not temSelecionado then
        statusTexto.Text = "Status: ERRO!\nSelecione pelo menos um mapa!"
        statusTexto.TextColor3 = Color3.fromRGB(255, 0, 0)
        task.wait(2)
        statusTexto.Text = "Status: Parado\nNenhum mapa selecionado"
        statusTexto.TextColor3 = Color3.fromRGB(200, 200, 200)
        return
    end
    
    config.ativo = not config.ativo
    
    if config.ativo then
        botaoIniciar.Text = "🟢 PARAR FARM"
        botaoIniciar.BackgroundColor3 = Color3.fromRGB(200, 0, 0)
        
        local nomes = {}
        for i = 1, 4 do
            if config.mapasSelecionados[i] then
                table.insert(nomes, mapas[i].nome)
            end
        end
        statusTexto.Text = "Status: FARMANDO\nMapas: " .. table.concat(nomes, ", ") .. "\n⏱️ Remote:" .. config.tempoAposRemote .. "ms | Coord:" .. config.tempoAposCoord .. "ms | Farm:" .. (config.tempoFarm / 1000) .. "s"
        statusTexto.TextColor3 = Color3.fromRGB(0, 255, 0)
        
        task.spawn(iniciarFarm)
    else
        botaoIniciar.Text = "🔴 INICIAR FARM"
        botaoIniciar.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        
        local count = 0
        for i = 1, 4 do
            if config.mapasSelecionados[i] then count = count + 1 end
        end
        statusTexto.Text = "Status: Parado\nMapas selecionados: " .. count
        statusTexto.TextColor3 = Color3.fromRGB(200, 200, 200)
    end
end)

