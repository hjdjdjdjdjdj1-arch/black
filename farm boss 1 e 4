local function atualizarStatusTrial(texto)
    local statusFrame = player.PlayerGui:FindFirstChild("AutoFarmGUI")
    if statusFrame and statusFrame:FindFirstChild("Frame") then
        local trialStatus = statusFrame.Frame:FindFirstChild("trialStatus")
        if trialStatus then
            trialStatus.Text = texto
            if config.pausado then
                trialStatus.TextColor3 = Color3.fromRGB(255, 100, 0)
            else
                trialStatus.TextColor3 = Color3.fromRGB(0, 255, 0)
            end
        end
    end
end

