local player = game.Players.LocalPlayer
local RS = game:GetService("ReplicatedStorage")

-- TELEPORT WORLD
local function teleportWorld(world,zone)

local args = {
    [1] = {
        [1] = {
            [1] = "Player",
            [2] = "Teleport",
            [3] = "Teleport",
            [4] = world,
            [5] = zone,
            ["n"] = 5
        },
        [2] = "\2"
    }
}

RS.BridgeNet.dataRemoteEvent:FireServer(unpack(args))

end

-- TP PLAYER
local function tp(pos)
local char = player.Character or player.CharacterAdded:Wait()
char:PivotTo(CFrame.new(pos))
end

-- TP BOSS
local function tpBoss(nome)

for _, npc in pairs(workspace.Client.Enemies:GetChildren()) do
if npc.Name == nome then

local root = npc:FindFirstChild("HumanoidRootPart")

if root then
tp(root.Position + Vector3.new(0,5,0))
end

end
end

end

