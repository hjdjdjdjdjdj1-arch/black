-- ========== REMOVER TELAS DE LOADING ==========
task.spawn(function()
    while true do
        for _, gui in pairs(player.PlayerGui:GetChildren()) do
            local nome = gui.Name:lower()
            if nome:find("loading") or nome:find("load") or 
               nome:find("teleport") or nome:find("fade") or
               nome:find("black") or nome:find("transition") then
                pcall(function() gui:Destroy() end)
            end
            if gui:IsA("Frame") and gui.BackgroundColor3 == Color3.new(0,0,0) then
                pcall(function() gui:Destroy() end)
            end
        end
        task.wait(0.1)
    end
end)
