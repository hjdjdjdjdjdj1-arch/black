-- ========== FUNÇÕES DA UI ==========
local function salvarConfiguracoes()
    local novoRemote = tonumber(remoteBox.Text)
    local novoCoord = tonumber(coordBox.Text)
    local novoFarm = tonumber(farmBox.Text)
    
    if novoRemote and novoRemote > 0 then
        config.tempoAposRemote = novoRemote
    end
    
    if novoCoord and novoCoord > 0 then
        config.tempoAposCoord = novoCoord
    end
    
    if novoFarm and novoFarm > 0 then
        config.tempoFarm = novoFarm
    end
    
    -- Atualiza os campos com os valores salvos
    remoteBox.Text = tostring(config.tempoAposRemote)
    coordBox.Text = tostring(config.tempoAposCoord)
    farmBox.Text = tostring(config.tempoFarm)
    
    statusTexto.Text = "✅ Configurações salvas!\nRemote: " .. config.tempoAposRemote .. "ms | Coord: " .. config.tempoAposCoord .. "ms | Farm: " .. (config.tempoFarm / 1000) .. "s"
    statusTexto.TextColor3 = Color3.fromRGB(0, 255, 0)
    task.wait(2)
    statusTexto.Text = "Status: Parado\nNenhum mapa selecionado"
    statusTexto.TextColor3 = Color3.fromRGB(200, 200, 200)
end

local function atualizarUI()
    local count = 0
    for i = 1, 4 do
        if config.mapasSelecionados[i] then
            botoes[i].Text = "✅ " .. mapas[i].nome
            botoes[i].BackgroundColor3 = Color3.fromRGB(0, 100, 0)
            count = count + 1
        else
            botoes[i].Text = "⬜ " .. mapas[i].nome
            botoes[i].BackgroundColor3 = Color3.fromRGB(40, 40, 60)
        end
    end
    
    if count > 0 then
        statusTexto.Text = "Status: Parado\nMapas selecionados: " .. count
        botaoIniciar.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        botaoIniciar.Text = "🔴 INICIAR FARM"
    else
        statusTexto.Text = "Status: Parado\nNenhum mapa selecionado"
        botaoIniciar.BackgroundColor3 = Color3.fromRGB(100, 100, 100)
    end
end

