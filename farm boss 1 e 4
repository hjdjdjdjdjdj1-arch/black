-- ========== DETECTAR MENSAGEM NO ANNOUNCEMENTS ==========
local function detectarAvisoAnnouncements()
    -- Procura em todas as GUIs
    for _, gui in pairs(player.PlayerGui:GetChildren()) do
        local nomeGui = gui.Name:lower()
        
        -- Procura por Announcements, Announce, Alert, Notification
        if nomeGui:find("announce") or 
           nomeGui:find("alert") or 
           nomeGui:find("notification") or
           nomeGui:find("system") or
           nomeGui:find("message") then
            
            -- Procura textos dentro da GUI
            for _, obj in pairs(gui:GetDescendants()) do
                if obj:IsA("TextLabel") or obj:IsA("TextButton") then
                    local texto = (obj.Text or ""):lower()
                    if texto:find("trial easy gamenmode has started") or
                       texto:find("trial started") or
                       texto:find("has started") then
                        return true
                    end
                end
            end
        end
        
        -- Também procura em qualquer TextLabel que contenha a mensagem
        for _, obj in pairs(gui:GetDescendants()) do
            if obj:IsA("TextLabel") then
                local texto = (obj.Text or ""):lower()
                if texto:find("trial easy gamenmode has started") or
                   texto:find("trial started") or
                   texto:find("has started") then
                    return true
                end
            end
        end
    end
    return false
end

-- ========== FUNÇÃO PARA ESPERAR TRIAL TERMINAR ==========
local function esperarTrialTerminar()
    print("🎯 TRIAL DETECTADA! Pausando teleporte...")
    config.pausado = true
    config.emTrial = true
    
    local tempoInicio = tick()
    local tempoDuracao = config.tempoDuracaoTrial / 1000
    
    while config.pausado and (tick() - tempoInicio) < tempoDuracao do
        local tempoRestante = tempoDuracao - (tick() - tempoInicio)
        atualizarStatusTrial(string.format("🎯 Trial ativa - Tempo restante: %.1f segundos", tempoRestante))
        task.wait(1)
    end
    
    config.pausado = false
    config.emTrial = false
    atualizarStatusTrial("✅ Trial finalizada! Retomando farm...")
    print("✅ Trial finalizada! Retomando teleporte...")
    task.wait(2)
    atualizarStatusTrial("✅ Trial inativa - Farmando")
end

-- ========== FUNÇÕES ==========
local function teleportWorld(mapa)
    RS.BridgeNet.dataRemoteEvent:FireServer(unpack(mapa.remote))
    print("🌍 Teleportando para: " .. mapa.nome)
end

local function tp(pos)
    local char = player.Character or player.CharacterAdded:Wait()
    local root = char:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = CFrame.new(pos)
    end
end

-- ========== FUNÇÃO DE FARM ==========
local function farmarMapa(mapa)
    print("\n📍 Farmando: " .. mapa.nome)
    
    teleportWorld(mapa)
    print("  ⏳ Aguardando " .. config.tempoAposRemote .. "ms...")
    task.wait(config.tempoAposRemote / 1000)
    
    tp(mapa.pos)
    print("  📍 Teleportado para coordenadas")
    print("  ⏳ Aguardando " .. config.tempoAposCoord .. "ms...")
    task.wait(config.tempoAposCoord / 1000)
    
    print("  ⚔️ Farmando por " .. (config.tempoFarm / 1000) .. " segundos...")
    task.wait(config.tempoFarm / 1000)
    
    print("✅ Farm concluído em: " .. mapa.nome)
end

-- ========== LOOP PRINCIPAL ==========
local function iniciarFarm()
    print("🚀 Iniciando farm nos mapas selecionados...")
    
    while config.ativo do
        -- Verifica se apareceu aviso no announcements
        if not config.emTrial and detectarAvisoAnnouncements() then
            esperarTrialTerminar()
        end
        
        -- Se não estiver pausado, farma
        if not config.pausado then
            for i = 1, 4 do
                if config.mapasSelecionados[i] then
                    if not config.ativo then break end
                    farmarMapa(mapas[i])
                end
            end
            print("\n🔄 Loop completo! Recomeçando...")
            task.wait(0.5)
        else
            task.wait(1)
        end
    end
end

-- ========== MONITORAMENTO CONTÍNUO ==========
task.spawn(function()
    while true do
        if config.ativo and not config.emTrial and not config.pausado then
            if detectarAvisoAnnouncements() then
                esperarTrialTerminar()
            end
        end
        task.wait(0.5) -- Verifica a cada 0.5 segundos
    end
end)

